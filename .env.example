# Provider keys
GROQ_API_KEY=            # free: console.groq.com/keys — lower ladder tiers
ANTHROPIC_API_KEY=       # console.anthropic.com — frontier tier (latest Opus) + baseline arm
GEMINI_API_KEY=          # hackathon sponsor — quality-gate judge (independent family, no self-grading bias)
OPENAI_API_KEY=          # optional comparison column
ELECTRICITYMAPS_TOKEN=   # free: api-portal.electricitymaps.com — live grid intensity

# Model ladder: provider:model, cheapest → frontier. The parity constraint and
# the baseline arm are both vs MODEL_HARD — latest Opus, per project requirement.
# (Fallback if no Anthropic key: groq:moonshotai/kimi-k2-instruct)
MODEL_TRIVIAL=groq:llama-3.1-8b-instant
MODEL_MODERATE=groq:llama-3.3-70b-versatile
MODEL_HARD=anthropic:claude-opus-4-8

# Quality-gate judge: independent model family (Gemini) scores every non-frontier
# answer, so no ladder model ever grades its own siblings. Fallback if no Gemini
# key: tier_plus_one (judge = next ladder rung up).
JUDGE_MODEL=gemini:gemini-2.5-flash

BASELINE_ZONE=US-MIDA-PJM
CARBON_ZONES=SE,FR,US-CAL-CISO,CA-ON,PL
QUALITY_FLOOR=0.85
CONFIDENCE_FLOOR=0.80  # trivial-tier self-confidence gate (D11) — below this, escalate, no judge call
EM_CACHE_S=60
PUE_DEFAULT=1.2
MAX_CONCURRENCY=4
